{
  "name": "@omnisupport/extension",
  "version": "1.0.0",
  "description": "OmniSupport AI Chrome Extension for Zendesk/Freshdesk",
  "private": true,
  "scripts": {
    "build": "npm run build:content && npm run build:background && npm run build:css && npm run copy",
    "build:content": "esbuild content.tsx --bundle --outfile=dist/content.js --target=chrome100 --loader:.tsx=tsx",
    "build:background": "esbuild background.ts --bundle --outfile=dist/background.js --target=chrome100 --format=esm",
    "build:css": "npx tailwindcss -i content.css -o dist/content.css --minify",
    "watch": "concurrently \"npm:watch:*\"",
    "watch:content": "npm run build:content -- --watch",
    "watch:background": "npm run build:background -- --watch",
    "watch:css": "npx tailwindcss -i content.css -o dist/content.css --watch",
    "copy": "copyfiles -f manifest.json popup.html dist/ && mkdir -p dist/icons && copyfiles -f icons/* dist/icons/",
    "dev": "npm run build",
    "package": "npm run build && cd dist && zip -r ../omnisupport-extension.zip .",
    "icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.0",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.20.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0"
  }
}
