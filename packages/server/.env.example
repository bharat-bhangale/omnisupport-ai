# OmniSupport AI - Environment Variables

NODE_ENV=development
PORT=3000
SERVER_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/omnisupport

# Redis (Upstash)
UPSTASH_REDIS_URL=https://your-instance.upstash.io
UPSTASH_REDIS_TOKEN=your_token

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_MGMT_API_TOKEN=your_mgmt_token

# OpenAI
OPENAI_API_KEY=sk-...

# Pinecone
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX=omnisupport

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Vapi.ai
VAPI_API_KEY=your_vapi_key
VAPI_WEBHOOK_SECRET=your_webhook_secret

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_key

# Deepgram
DEEPGRAM_API_KEY=your_deepgram_key

# AssemblyAI
ASSEMBLYAI_API_KEY=your_assemblyai_key

# Zendesk (optional)
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_EMAIL=admin@yourcompany.com
ZENDESK_TOKEN=your_zendesk_token

# Freshdesk (optional)
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_key

# Salesforce (optional)
SALESFORCE_CLIENT_ID=your_sf_client_id
SALESFORCE_CLIENT_SECRET=your_sf_client_secret

# Stripe (optional)
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS S3
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=omnisupport-assets

# Slack (optional)
SLACK_BOT_TOKEN=xoxb-...

# SendGrid (optional)
SENDGRID_API_KEY=SG...

# IPQualityScore (optional, for fraud detection)
IPQUALITYSCORE_API_KEY=your_key

# Encryption key (32+ chars for AES-256)
INTEGRATION_ENCRYPTION_KEY=your_32_character_encryption_key_here
