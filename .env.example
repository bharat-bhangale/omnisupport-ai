# OmniSupport-AI Environment Variables Template
# Copy this file to .env and fill in the values

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
SERVER_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# ============================================
# Database
# ============================================
MONGODB_URI=mongodb://localhost:27017/omnisupport

# ============================================
# Redis (Upstash compatible)
# ============================================
UPSTASH_REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_TOKEN=

# ============================================
# Auth0 Configuration
# ============================================
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.omnisupport.ai
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# ============================================
# OpenAI
# ============================================
OPENAI_API_KEY=sk-...

# ============================================
# Pinecone (Vector Database)
# ============================================
PINECONE_API_KEY=
PINECONE_INDEX=omnisupport

# ============================================
# Twilio (SMS/Phone)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# Vapi (Voice AI)
# ============================================
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# ============================================
# ElevenLabs (Text-to-Speech)
# ============================================
ELEVENLABS_API_KEY=

# ============================================
# Deepgram (Speech-to-Text)
# ============================================
DEEPGRAM_API_KEY=

# ============================================
# AssemblyAI (Speech-to-Text Alternative)
# ============================================
ASSEMBLYAI_API_KEY=

# ============================================
# AWS (S3 Storage)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ============================================
# Integrations
# ============================================
# Encryption key for storing integration credentials (must be 32+ characters)
INTEGRATION_ENCRYPTION_KEY=change-this-to-a-secure-random-string-at-least-32-chars

# Freshdesk
FRESHDESK_WEBHOOK_SECRET=

# Zendesk
ZENDESK_CLIENT_ID=
ZENDESK_CLIENT_SECRET=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# SendGrid (Email)
SENDGRID_API_KEY=

# ============================================
# Docker Configuration
# ============================================
SERVER_PORT=3000
CLIENT_PORT=80
MONGO_PORT=27017
REDIS_PORT=6379
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_this_password

# ============================================
# Client Build Configuration
# ============================================
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000
